<?xml version="1.0" encoding="utf-8"?>
<!-- Pin the solution to a single package source so central package management is reproducible
     regardless of any machine-global NuGet sources (e.g. a "github" source). `clear` drops inherited
     sources; packageSourceMapping satisfies NU1507 by routing every package to nuget.org even if
     another source survives in the machine/user config. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
