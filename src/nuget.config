<?xml version="1.0" encoding="utf-8"?>
<!-- Pin the solution to a single package source so central package management is reproducible
     regardless of any machine-global NuGet sources. All dependencies come from nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
