<?xml version="1.0" encoding="utf-8"?>
<!-- Pin the solution to a single package source for CLI restores. The authoritative single-source
     guarantee for ALL restores (incl. Visual Studio over a \\wsl.localhost path, where this file may
     not be discovered) is `RestoreSources` in Directory.Build.props. `clear` drops inherited sources
     (e.g. a machine-global "github" source) so central package management has one unambiguous source. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
