<?xml version="1.0" encoding="utf-8"?>
<!-- Pin the solution to nuget.org. `clear` drops any machine-global sources (e.g. a "github" feed)
     so central package management restores from one unambiguous source. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
