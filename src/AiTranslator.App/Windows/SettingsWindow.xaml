<Window x:Class="AiTranslator.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:res="clr-namespace:AiTranslator.App.Resources"
        Title="{x:Static res:UiStrings.SettingsTitle}"
        Width="560" Height="660" MinWidth="480" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app.ico"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Language row: vector flag + native name + muted code -->
        <DataTemplate x:Key="LangItem">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Flag}" Width="22" Height="15" Stretch="Fill"
                       SnapsToDevicePixels="True" Margin="0,0,10,0" />
                <ui:TextBlock Text="{Binding Native}" VerticalAlignment="Center" />
                <ui:TextBlock Text="{Binding CodeUpper}" FontSize="11" VerticalAlignment="Center"
                              Margin="8,1,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="20,18,20,14">
            <Border Width="34" Height="34" CornerRadius="9" VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF4C95FF" Offset="0" />
                        <GradientStop Color="#FF2C6BE0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <ui:TextBlock Text="⇄" Foreground="White" FontSize="18" FontWeight="Bold"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <ui:TextBlock Text="{x:Static res:UiStrings.AppName}" FontTypography="BodyStrong" />
                <ui:TextBlock Text="{x:Static res:UiStrings.SettingsHeading}" FontTypography="Caption"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Subtle error line (auto-save means no Save button / no "saved" message; only failures surface) -->
        <ui:TextBlock x:Name="ErrorText" DockPanel.Dock="Bottom" Margin="20,0,20,12"
                      TextWrapping="Wrap" Visibility="Collapsed"
                      Foreground="{DynamicResource SystemFillColorCriticalBrush}" />

        <TabControl Margin="12,0,12,4">
            <!-- ================= GENERAL ================= -->
            <TabItem Header="{x:Static res:UiStrings.SettingsTabGeneral}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="{x:Static res:UiStrings.SettingsLanguages}" Margin="2,0,0,2" />
                        <ui:TextBlock FontTypography="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      TextWrapping="Wrap" Margin="2,0,0,8" Text="{x:Static res:UiStrings.SettingsLanguagesHint}" />
                        <ui:Card Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <ui:TextBlock FontTypography="Caption" Margin="2,0,0,5"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Text="{x:Static res:UiStrings.SettingsPrimaryLang}" />
                                    <ComboBox x:Name="PrimaryCombo" HorizontalAlignment="Stretch"
                                              ItemTemplate="{StaticResource LangItem}" MaxDropDownHeight="320" />
                                </StackPanel>
                                <ui:TextBlock Grid.Column="1" Text="⇄" FontSize="16" HorizontalAlignment="Center"
                                              VerticalAlignment="Bottom" Margin="0,0,0,8"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Column="2">
                                    <ui:TextBlock FontTypography="Caption" Margin="2,0,0,5"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                  Text="{x:Static res:UiStrings.SettingsSecondaryLang}" />
                                    <ComboBox x:Name="SecondaryCombo" HorizontalAlignment="Stretch"
                                              ItemTemplate="{StaticResource LangItem}" MaxDropDownHeight="320" />
                                </StackPanel>
                            </Grid>
                        </ui:Card>

                        <ui:TextBlock FontTypography="BodyStrong" Text="{x:Static res:UiStrings.SettingsBehavior}" Margin="2,0,0,8" />
                        <ui:Card Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <ui:TextBlock Text="{x:Static res:UiStrings.SettingsAutoDirection}" />
                                        <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Text="{x:Static res:UiStrings.SettingsAutoDirectionHint}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" x:Name="AutoDirectionBox" VerticalAlignment="Center" />
                                </Grid>
                                <Separator Margin="0,8" />
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <ui:TextBlock Text="{x:Static res:UiStrings.SettingsAutoAppearBadge}" />
                                        <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Text="{x:Static res:UiStrings.SettingsAutoAppearBadgeHint}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" x:Name="AutoAppearBadgeBox" VerticalAlignment="Center" />
                                </Grid>
                                <Separator Margin="0,8" />
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <ui:TextBlock Text="{x:Static res:UiStrings.SettingsRunAtStartup}" />
                                        <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Text="{x:Static res:UiStrings.SettingsRunAtStartupHint}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" x:Name="RunAtStartupBox" VerticalAlignment="Center" />
                                </Grid>
                                <Separator Margin="0,8" />
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <ui:TextBlock Text="{x:Static res:UiStrings.SettingsSelectionTranslator}" />
                                        <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Text="{x:Static res:UiStrings.SettingsSelectionTranslatorHint}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" x:Name="SelectionTranslatorBox" VerticalAlignment="Center" />
                                </Grid>
                                <Separator Margin="0,8" />
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <ui:TextBlock Text="{x:Static res:UiStrings.SettingsHumanize}" />
                                        <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap"
                                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                      Text="{x:Static res:UiStrings.SettingsHumanizeHint}" />
                                    </StackPanel>
                                    <ui:ToggleSwitch Grid.Column="1" x:Name="HumanizeBox" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <ui:Card>
                            <StackPanel>
                                <ui:TextBlock Text="{x:Static res:UiStrings.SettingsModel}" Margin="0,0,0,6" />
                                <ui:TextBox x:Name="ModelBox" HorizontalAlignment="Stretch" />
                                <ui:TextBlock Text="{x:Static res:UiStrings.SettingsHotkey}" Margin="0,16,0,6" />
                                <ui:TextBox x:Name="HotkeyBox" HorizontalAlignment="Stretch" />
                                <ui:TextBlock FontTypography="Caption" TextWrapping="Wrap" Margin="0,4,0,0"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Text="{x:Static res:UiStrings.SettingsHotkeyHint}" />
                                <ui:TextBlock x:Name="HotkeyHint" FontTypography="Caption" Margin="0,4,0,0"
                                              Foreground="{DynamicResource SystemFillColorCriticalBrush}" Visibility="Collapsed" />
                            </StackPanel>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= ACCOUNT ================= -->
            <TabItem Header="{x:Static res:UiStrings.SettingsTabAccount}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,12">
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="{x:Static res:UiStrings.SettingsApiKey}" Margin="2,0,0,2" />
                        <ui:TextBlock FontTypography="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      TextWrapping="Wrap" Margin="2,0,0,8" Text="{x:Static res:UiStrings.SettingsApiKeyHint}" />
                        <ui:Card>
                            <ui:PasswordBox x:Name="ApiKeyBox" HorizontalAlignment="Stretch"
                                            PlaceholderText="{x:Static res:UiStrings.SettingsApiKeyPlaceholder}" />
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= BLOCK LIST ================= -->
            <TabItem Header="{x:Static res:UiStrings.SettingsTabBlockList}">
                <DockPanel Margin="8,12">
                    <ui:TextBlock DockPanel.Dock="Top" FontTypography="Caption" TextWrapping="Wrap" Margin="2,0,2,12"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="{x:Static res:UiStrings.SettingsBlockListHint}" />
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" x:Name="BlocklistAddBox" KeyDown="OnBlocklistAddKeyDown"
                                    PlaceholderText="{x:Static res:UiStrings.SettingsBlockListAddPlaceholder}" />
                        <ui:Button Grid.Column="1" Margin="8,0,0,0" Appearance="Primary" MinWidth="72"
                                   Content="{x:Static res:UiStrings.SettingsBlockListAdd}" Click="OnBlocklistAddClick">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Add24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                    <ui:Card>
                        <Grid>
                            <ui:TextBlock x:Name="BlocklistEmpty" FontTypography="Caption" Margin="6,10"
                                          HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="{x:Static res:UiStrings.SettingsBlockListEmpty}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="BlocklistItems">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ui:TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"
                                                              TextTrimming="CharacterEllipsis" />
                                                <ui:Button Grid.Column="1" Appearance="Transparent" Padding="8,4" Tag="{Binding}"
                                                           ToolTip="{x:Static res:UiStrings.SettingsBlockListRemove}"
                                                           Click="OnBlocklistRemoveClick">
                                                    <ui:Button.Icon>
                                                        <ui:SymbolIcon Symbol="Delete24" />
                                                    </ui:Button.Icon>
                                                </ui:Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </ui:Card>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
