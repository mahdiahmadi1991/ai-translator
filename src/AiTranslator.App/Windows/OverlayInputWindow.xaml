<Window x:Class="AiTranslator.App.Windows.OverlayInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:AiTranslator.App.Resources"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="460"
        SizeToContent="Height">
    <Window.Resources>
        <Style x:Key="Primary" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF2D7DF6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FF3A8AFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bg" Property="Background" Value="#FF3A3A42" />
                                <Setter Property="Foreground" Value="#FF8A8A93" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Foreground" Value="#FF9AA4B2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="5" Padding="6,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF2C2C34" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#FF1E1E1E" BorderBrush="#FF3A3A3A" BorderThickness="1">
        <DockPanel>
            <!-- Header: logo + direction (left); settings + close (right) -->
            <Border DockPanel.Dock="Top" Background="#FF242427" BorderBrush="#FF333338" BorderThickness="0,0,0,1"
                    CornerRadius="10,10,0,0" Padding="10,7">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button x:Name="SettingsButton" Style="{StaticResource IconButton}" Click="OnSettingsClick"
                                Content="&#xE713;" ToolTip="{x:Static res:UiStrings.BadgeSettings}" />
                        <Button x:Name="CloseButton" Style="{StaticResource IconButton}" Click="OnCloseClick"
                                Content="&#xE711;" ToolTip="{x:Static res:UiStrings.OverlayClose}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="4" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF4C95FF" Offset="0" />
                                    <GradientStop Color="#FF2C6BE0" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⇄" Foreground="White" FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="DirectionLabel" Foreground="#FFC9D4E6" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Footer: status (left) + Translate (right) — room for more later -->
            <Border DockPanel.Dock="Bottom" Background="#FF1A1A1C" BorderBrush="#FF333338" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10" Padding="10,8">
                <DockPanel>
                    <Button x:Name="TranslateButton" DockPanel.Dock="Right" Style="{StaticResource Primary}"
                            Click="OnTranslateClick" Content="{x:Static res:UiStrings.OverlayTranslate}" ToolTip="Ctrl+Enter" />
                    <TextBlock x:Name="Status" VerticalAlignment="Center" Foreground="#FFE06C75" FontSize="11"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,10,0" />
                </DockPanel>
            </Border>

            <!-- Body -->
            <TextBox x:Name="Input"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Background="Transparent"
                     Foreground="White"
                     CaretBrush="White"
                     BorderThickness="0"
                     FontSize="16"
                     Height="130"
                     Margin="12,10"
                     VerticalScrollBarVisibility="Auto" />
        </DockPanel>
    </Border>
</Window>
