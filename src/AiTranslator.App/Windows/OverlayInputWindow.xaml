<Window x:Class="AiTranslator.App.Windows.OverlayInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:res="clr-namespace:AiTranslator.App.Resources"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="460"
        SizeToContent="Height"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI, Tahoma">

    <Window.Resources>
        <!-- Rewrite-style dropdown item: icon + name -->
        <DataTemplate x:Key="StyleItem">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                <ui:TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <!-- Opaque base: the themed card brush is translucent (meant to sit over a Mica backdrop), which
         left this stand-alone transparent window glassy and hard to read. Use a solid dark fill. -->
    <Border CornerRadius="10" BorderThickness="1"
            Background="#FF1E1E22"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
        <DockPanel>
            <!-- Header: logo + direction (left); settings + close (right). Drag it to move the box. -->
            <Border DockPanel.Dock="Top" Background="#14FFFFFF" CornerRadius="10,10,0,0" Padding="10,6"
                    MouseLeftButtonDown="OnHeaderMouseDown" Cursor="SizeAll">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <ui:Button x:Name="SettingsButton" Appearance="Transparent" Padding="6,4" Click="OnSettingsClick"
                                   ToolTip="{x:Static res:UiStrings.BadgeSettings}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Settings24" FontSize="16" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button x:Name="CloseButton" Appearance="Transparent" Padding="6,4" Click="OnCloseClick"
                                   ToolTip="{x:Static res:UiStrings.OverlayClose}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="4" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF4C95FF" Offset="0" />
                                    <GradientStop Color="#FF2C6BE0" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="ArrowSwap24" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ui:TextBlock x:Name="DirectionLabel" FontTypography="BodyStrong" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Footer: rewrite-style picker (left) + spinner + Translate (right).
                 NOTE ON DOCK ORDER: the footer is declared before the status row so the footer sits at
                 the very bottom and the (normally-collapsed) status line appears just above it. -->
            <Border DockPanel.Dock="Bottom" Background="#0AFFFFFF" CornerRadius="0,0,10,10" Padding="10,8">
                <DockPanel>
                    <ui:Button x:Name="TranslateButton" DockPanel.Dock="Right" Appearance="Primary"
                               Click="OnTranslateClick" Content="{x:Static res:UiStrings.OverlayTranslate}" ToolTip="Ctrl+Enter">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Translate24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:ProgressRing x:Name="Busy" DockPanel.Dock="Right" Width="20" Height="20"
                                     Margin="0,0,10,0" VerticalAlignment="Center"
                                     IsIndeterminate="True" Visibility="Collapsed" />
                    <ComboBox x:Name="StyleCombo" DockPanel.Dock="Left" Width="172"
                              ItemTemplate="{StaticResource StyleItem}" MaxDropDownHeight="340"
                              ToolTip="{x:Static res:UiStrings.OverlayStyleLabel}"
                              AutomationProperties.Name="{x:Static res:UiStrings.OverlayStyleLabel}" />
                </DockPanel>
            </Border>

            <!-- Error/status line — collapsed unless a translation fails. Sits above the footer. -->
            <Border DockPanel.Dock="Bottom" Background="Transparent" Padding="10,0,10,6">
                <ui:TextBlock x:Name="Status" FontTypography="Caption"
                              Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                              TextWrapping="Wrap" Visibility="Collapsed" />
            </Border>

            <!-- Body -->
            <ui:TextBox x:Name="Input"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        ClearButtonEnabled="False"
                        BorderThickness="0"
                        Background="Transparent"
                        FontSize="16"
                        Height="130"
                        Margin="8,8"
                        VerticalScrollBarVisibility="Auto"
                        PlaceholderText="{x:Static res:UiStrings.OverlayPlaceholder}" />
        </DockPanel>
    </Border>
</Window>
