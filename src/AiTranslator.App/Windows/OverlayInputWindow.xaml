<Window x:Class="AiTranslator.App.Windows.OverlayInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:AiTranslator.App.Resources"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="440"
        SizeToContent="Height">
    <Border CornerRadius="10" Background="#FF1E1E1E" BorderBrush="#FF3A3A3A" BorderThickness="1" Padding="12">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top"
                       Text="{x:Static res:UiStrings.OverlayHint}"
                       Foreground="#FF888888" FontSize="11" Margin="2,0,2,6" />
            <TextBlock x:Name="Status" DockPanel.Dock="Bottom"
                       Foreground="#FFE06C75" FontSize="11" Margin="2,6,2,0"
                       TextWrapping="Wrap" Visibility="Collapsed" />
            <TextBox x:Name="Input"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FlowDirection="RightToLeft"
                     Background="Transparent"
                     Foreground="White"
                     CaretBrush="White"
                     BorderThickness="0"
                     FontSize="16"
                     MinHeight="64"
                     MaxHeight="220"
                     VerticalScrollBarVisibility="Auto" />
        </DockPanel>
    </Border>
</Window>
