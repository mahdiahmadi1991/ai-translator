<Window x:Class="AiTranslator.App.Windows.SelectionResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:res="clr-namespace:AiTranslator.App.Resources"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="440"
        SizeToContent="Height"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI">

    <Window.Resources>
        <DataTemplate x:Key="LangItem">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding Flag}" Width="20" Height="14" Stretch="Fill"
                       SnapsToDevicePixels="True" Margin="0,0,8,0" />
                <ui:TextBlock Text="{Binding Native}" VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="10" BorderThickness="1"
            Background="#FF1E1E22"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
        <DockPanel>
            <!-- Header: logo + direction (left); close (right). Drag to move. -->
            <Border DockPanel.Dock="Top" Background="#14FFFFFF" CornerRadius="10,10,0,0" Padding="10,6"
                    MouseLeftButtonDown="OnHeaderMouseDown" Cursor="SizeAll">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Appearance="Transparent" Padding="6,4" Click="OnCloseClick"
                               ToolTip="{x:Static res:UiStrings.OverlayClose}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="4" Margin="0,0,8,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF4C95FF" Offset="0" />
                                    <GradientStop Color="#FF2C6BE0" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="Translate24" Foreground="White" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ui:TextBlock x:Name="DirectionLabel" FontTypography="BodyStrong" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Footer: target language (left) + spinner + copy (right) -->
            <Border DockPanel.Dock="Bottom" Background="#0AFFFFFF" CornerRadius="0,0,10,10" Padding="10,8">
                <DockPanel>
                    <ui:Button x:Name="CopyButton" DockPanel.Dock="Right" Appearance="Secondary"
                               Click="OnCopyClick" Content="{x:Static res:UiStrings.SelectionCopy}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Copy24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:ProgressRing x:Name="Busy" DockPanel.Dock="Right" Width="18" Height="18"
                                     Margin="0,0,10,0" VerticalAlignment="Center"
                                     IsIndeterminate="True" Visibility="Collapsed" />
                    <ComboBox x:Name="TargetCombo" DockPanel.Dock="Left" Width="150"
                              ItemTemplate="{StaticResource LangItem}" MaxDropDownHeight="300"
                              ToolTip="{x:Static res:UiStrings.SelectionTargetLang}" />
                </DockPanel>
            </Border>

            <!-- Body: the translation (read-only, selectable) -->
            <TextBox x:Name="Output"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                     FontSize="15"
                     MaxHeight="240"
                     MinHeight="60"
                     Margin="8,8"
                     VerticalScrollBarVisibility="Auto" />
        </DockPanel>
    </Border>
</Window>
